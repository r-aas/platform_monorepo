@prefix : <http://r-aas.dev/ontology/platform#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

# ════════════════════════════════════════════
# Platform Instances — R's k3d mewtwo cluster
# Generated from: kubectl get svc,ingress -A
# Last updated: 2026-03-29
# ════════════════════════════════════════════

# ── Host infrastructure ───────────────────

:mac-host a :System ;
    rdfs:label "M4 Max MacBook Pro" ;
    rdfs:comment "Physical host. 16 cores (12P+4E), 128 GB RAM. Runs Ollama natively (Metal GPU)." ;
    :contains :ollama, :colima, :claude-runner, :yt-ingest .

:colima a :System ;
    rdfs:label "Colima" ;
    rdfs:comment "Linux VM (dockerd engine). 8 CPU, 32 GB RAM, 200 GB disk." ;
    :memberOf :mac-host ;
    :contains :k3d .

:k3d a :System ;
    rdfs:label "k3d" ;
    rdfs:comment "k3s-in-Docker." ;
    :memberOf :colima ;
    :contains :mewtwo .

# ── Host services (Mac native) ──────────

:ollama a :Service ;
    rdfs:label "Ollama" ;
    rdfs:comment "Native on Mac host (Metal GPU). Models: glm-4.7-flash (default), qwen2.5:14b, qwen2.5:7b. OLLAMA_NUM_PARALLEL=4, OLLAMA_FLASH_ATTENTION=1." ;
    :port 11434 ;
    :protocol "http" ;
    :address "192.168.5.2" .

:claude-runner a :AgentRuntime ;
    rdfs:label "Claude Runner" ;
    rdfs:comment "Headless Claude CLI session manager. Runtimes: claude, openclaw, generic. Mac host service." ;
    :port 7777 ;
    :protocol "http" ;
    :healthPath "/health" ;
    :address "192.168.5.2" .

:yt-ingest a :ETLService ;
    rdfs:label "YouTube Ingest" ;
    rdfs:comment "yt-dlp + transcript extraction. Supports playlists, Watch Later via browser cookies." ;
    :port 7778 ;
    :protocol "http" ;
    :healthPath "/health" ;
    :address "192.168.5.2" .

# ── Cluster ───────────────────────────────

:mewtwo a :Cluster ;
    rdfs:label "mewtwo" ;
    rdfs:comment "k3d shared cluster. Ports 80/443, ingress-nginx." ;
    :memberOf :k3d ;
    :contains :ns-platform, :ns-genai, :ns-ingress-nginx .

# ── Namespaces ────────────────────────────

:ns-platform a :Namespace ;
    rdfs:label "platform" ;
    :memberOf :mewtwo ;
    :contains :gitlab, :argocd .

:ns-genai a :Namespace ;
    rdfs:label "genai" ;
    :memberOf :mewtwo ;
    :contains :n8n, :litellm, :mlflow, :minio, :agent-gateway, :open-ontologies,
              :langfuse-web,
              :plane-web, :plane-api, :plane-live, :plane-space, :plane-admin, :plane-minio, :plane-rabbitmq,
              :kagent-controller, :kagent-tools, :kagent-ui,
              :developer-agent, :mlops-agent, :platform-admin-agent,
              :datahub-gms, :datahub-frontend, :datahub-actions,
              :datahub-mysql, :datahub-elasticsearch, :datahub-kafka, :datahub-zookeeper,
              :datahub-bridge,
              :mcp-kubernetes, :mcp-gitlab, :mcp-n8n, :mcp-datahub, :mcp-plane,
              :pg-mlflow, :pg-n8n, :pg-plane, :pgvector,
              :langfuse-clickhouse, :langfuse-redis, :langfuse-zookeeper .

:ns-ingress-nginx a :Namespace ;
    rdfs:label "ingress-nginx" ;
    :memberOf :mewtwo ;
    :contains :ingress-nginx .

# ── Ingress ─────────────────────────────

:ingress-nginx a :Service ;
    rdfs:label "Ingress NGINX" ;
    rdfs:comment "Cluster ingress controller. NodePort 80/443." ;
    :port 80 ;
    :protocol "http" ;
    :address "ingress-nginx-controller.ingress-nginx.svc.cluster.local" .

# ── Platform namespace ────────────────────

:gitlab a :GitServer ;
    rdfs:label "GitLab CE" ;
    :port 80 ;
    :protocol "http" ;
    :healthPath "/-/readiness" ;
    :image "gitlab/gitlab-ce:18.0.0-ce.0" ;
    :ingressHost "gitlab.mewtwo.127.0.0.1.nip.io" ;
    :lanIngressHost "gitlab.mewtwo.192.0.0.2.nip.io" ;
    :address "gitlab-ce.platform.svc.cluster.local" .

:argocd a :GitOpsController ;
    rdfs:label "ArgoCD" ;
    rdfs:comment "24 apps, all Synced/Healthy. Bootstrap-only helmfile, day-2 via GitOps." ;
    :port 80 ;
    :protocol "http" ;
    :healthPath "/healthz" ;
    :address "argocd-server.platform.svc.cluster.local" ;
    :ingressHost "argocd.mewtwo.127.0.0.1.nip.io" ;
    :lanIngressHost "argocd.mewtwo.192.0.0.2.nip.io" .

# ── GenAI namespace — core services ──────

:n8n a :WorkflowEngine ;
    rdfs:label "n8n" ;
    rdfs:comment "15 workflows (12 active). Env vars from n8n-env-secrets. Encryption key from k8s secret." ;
    :port 5678 ;
    :protocol "http" ;
    :healthPath "/healthz" ;
    :image "n8nio/n8n:1.123.21" ;
    :ingressHost "n8n.mewtwo.127.0.0.1.nip.io" ;
    :lanIngressHost "n8n.mewtwo.192.0.0.2.nip.io" ;
    :address "genai-n8n.genai.svc.cluster.local" ;
    :dependsOn :litellm, :mlflow, :pg-n8n, :plane-api .

:litellm a :LLMProxy ;
    rdfs:label "LiteLLM" ;
    rdfs:comment "Routes to Ollama at 192.168.5.2:11434. Default model: glm-4.7-flash. Timeout: 300s." ;
    :port 4000 ;
    :protocol "http" ;
    :healthPath "/health" ;
    :ingressHost "litellm.genai.127.0.0.1.nip.io" ;
    :lanIngressHost "litellm.genai.192.0.0.2.nip.io" ;
    :address "genai-litellm.genai.svc.cluster.local" ;
    :dependsOn :ollama .

:mlflow a :MLPlatform ;
    rdfs:label "MLflow" ;
    rdfs:comment "Experiment tracking, prompt registry. disableSecurityMiddleware for DNS rebinding fix." ;
    :port 80 ;
    :protocol "http" ;
    :healthPath "/health" ;
    :ingressHost "mlflow.genai.127.0.0.1.nip.io" ;
    :lanIngressHost "mlflow.genai.192.0.0.2.nip.io" ;
    :address "genai-mlflow.genai.svc.cluster.local" ;
    :dependsOn :minio, :pg-mlflow .

:minio a :ObjectStore ;
    rdfs:label "MinIO" ;
    rdfs:comment "MLflow artifact storage." ;
    :port 9000 ;
    :protocol "http" ;
    :ingressHost "minio.genai.127.0.0.1.nip.io" ;
    :lanIngressHost "minio.genai.192.0.0.2.nip.io" ;
    :address "genai-minio.genai.svc.cluster.local" .

:agent-gateway a :APIService ;
    rdfs:label "Agent Gateway" ;
    rdfs:comment "Unified: agent registry (PG+pgvector), OpenAI chat, MCP proxy, A2A cards, sandbox, skill catalog. 4 agents, 10 skills, 5 MCP servers." ;
    :port 8000 ;
    :protocol "http" ;
    :healthPath "/health/detail" ;
    :ingressHost "agent-gateway.genai.127.0.0.1.nip.io" ;
    :lanIngressHost "agent-gateway.genai.192.0.0.2.nip.io" ;
    :address "genai-agent-gateway.genai.svc.cluster.local" ;
    :dependsOn :litellm, :pgvector, :mcp-kubernetes, :mcp-gitlab, :mcp-n8n, :mcp-datahub, :mcp-plane .

:open-ontologies a :MCPServer ;
    rdfs:label "Open Ontologies" ;
    rdfs:comment "OWL2/SHACL reasoning engine. Rust MCP server." ;
    :port 8080 ;
    :protocol "http" ;
    :ingressHost "open-ontologies.genai.127.0.0.1.nip.io" ;
    :lanIngressHost "open-ontologies.genai.192.0.0.2.nip.io" ;
    :address "genai-open-ontologies.genai.svc.cluster.local" .

