## Shared environment variables — sourced by all projects
## Override per-repo in .env or .env.local

# Ollama / OpenAI-compatible inference
OPENAI_BASE_URL=http://localhost:11434/v1
OPENAI_API_KEY=ollama
OPENAI_MODEL=glm-4.7-flash

# Ollama performance (autoresearch: +25% throughput on M4 Max)
# Flash attention reduces memory access during self-attention
# Max 1 loaded model prevents GPU memory exhaustion with large models
OLLAMA_FLASH_ATTENTION=1
OLLAMA_MAX_LOADED_MODELS=1
OLLAMA_NUM_PARALLEL=4

# GitLab
GITLAB_URL=http://gitlab.platform.127.0.0.1.nip.io
REGISTRY_URL=registry.platform.127.0.0.1.nip.io

# Cluster
K3D_CLUSTER=mewtwo
K8S_NAMESPACE=dev
NIP_DOMAIN=127.0.0.1.nip.io

# Architecture: arm64 (Apple Silicon) or amd64 (Intel/cloud/CI)
PLATFORM_ARCH=arm64
