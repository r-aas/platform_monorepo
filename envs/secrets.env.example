## Platform secrets — copy to secrets.env and fill in values
## Usage: cp envs/secrets.env.example envs/secrets.env
## Then: task seed-secrets
##
## For local dev, you can use any values — these are only used inside k3d.
## Generate random passwords: openssl rand -hex 16

# PostgreSQL passwords (one per database)
PG_MLFLOW_PASSWORD=changeme-mlflow
PG_LANGFUSE_PASSWORD=changeme-langfuse
PG_PLANE_PASSWORD=changeme-plane

# MLflow
MLFLOW_FLASK_SECRET_KEY=changeme-flask-key

# MinIO (S3 storage)
MINIO_ROOT_USER=admin
MINIO_ROOT_PASSWORD=changeme-minio

# LiteLLM (LLM proxy auth)
LITELLM_API_KEY=sk-litellm-local

# GitLab (generated during task up — leave blank for auto-setup)
GITLAB_PAT=

# Plane (project management)
PLANE_API_TOKEN=changeme-plane-token

# Langfuse (LLM observability)
LANGFUSE_PUBLIC_KEY=pk-lf-local
LANGFUSE_SECRET_KEY=sk-lf-local

# DataHub (data catalog)
DATAHUB_MYSQL_ROOT_PASSWORD=changeme-datahub
